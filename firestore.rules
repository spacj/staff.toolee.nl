rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isAuth() && userDoc().role == 'admin'; }
    function isManager() { return isAuth() && (userDoc().role == 'admin' || userDoc().role == 'manager'); }
    function isWebmaster() { return isAuth() && userDoc().role == 'webmaster'; }
    function isInventory() { return isAuth() && userDoc().role == 'inventory'; }

    // Users: anyone can read, only self or admin can write
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAuth() && request.auth.uid == uid;
    }

    // Organizations: all authenticated can read, managers can update, owner can delete
    // Inventory role can update too (needed to add stock categories stored on org doc)
    match /organizations/{orgId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isManager() || isInventory();
      allow delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // Config (PayPal plan IDs etc): admins write, all auth read
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Invites: public read (unauthenticated /join page needs to verify codes)
    match /invites/{id} {
      allow read: if true;
      allow create: if isManager();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // Workers: all auth read, managers+ write
    match /workers/{id} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // Shops: all auth read, managers+ write
    match /shops/{id} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // Shift Templates: all auth read, managers+ write
    match /shiftTemplates/{id} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isManager();
    }

    // Shifts: all auth read, managers+ write
    match /shifts/{id} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isManager();
    }

    // Shift Preferences: all auth read/write (workers set their own)
    match /shiftPreferences/{id} {
      allow read, write: if isAuth();
    }

    // Attendance: all auth read/create/update (workers clock in/out)
    match /attendance/{id} {
      allow read, create, update: if isAuth();
    }

    // Permits: all auth read/create (workers request), managers approve/deny/delete
    match /permits/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isManager();
    }

    // Payments: all auth read, managers/admins create, admin update (webhooks use admin SDK which bypasses rules)
    match /payments/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // Notifications: all auth read/update own, managers create
    match /notifications/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Activity Log: all auth read/create
    match /activityLog/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Referrals: all auth read, auth create
    match /referrals/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Correction Requests: all auth read/create (workers submit), managers update (approve/reject)
    match /correctionRequests/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isManager();
    }

    // Messages: all auth read/create (workers send, managers reply), auth update (mark read)
    match /messages/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Webmaster Referral Codes: auth read/write (access enforced in app via isWebmaster)
    match /webmasterReferralCodes/{id} {
      allow read, create, update, delete: if isAuth();
    }

    // Webmaster Earnings: auth read/write (access enforced in app via isWebmaster)
    match /webmasterEarnings/{id} {
      allow read, create, update, delete: if isAuth();
    }

    // Support Tickets: public create (contact form), auth read/write
    match /supportTickets/{id} {
      allow read: if isAuth();
      allow create: if true;  // Public contact form (no auth required)
      allow update: if isAuth();
    }

    // Staff Availability: workers submit/manage own, managers/admins read/write all
    // Schema: { orgId, workerId, workerName, date, shiftType, status, createdAt, updatedAt }
    match /staffAvailability/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Checklist Templates: all auth read, managers+ create/update/delete
    match /checklistTemplates/{id} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isManager();
    }

    // Checklist Assignments: all auth read/create/update (workers check items), managers delete
    match /checklistAssignments/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isManager();
    }

    // Knowledge Base Categories: all auth read, managers+ create/update/delete
    match /kbCategories/{id} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isManager();
    }

    // Knowledge Base Articles: all auth read, managers+ create/update/delete
    match /kbArticles/{id} {
      allow read: if isAuth();
      allow create: if isManager();
      allow update: if isManager();
      allow delete: if isManager();
    }

    // Public Checklist Assignments: anyone can create (via server-side API), authenticated can read, managers can delete
    // Public assignments are created server-side via API route so no client-side rules needed for create
    match /publicChecklistAssignments/{id} {
      allow read: if isAuth();
      allow create: if true;  // Server-side validated via API route
      allow update: if isAuth();
      allow delete: if isManager();
    }

    // Checklist History: managers/admins can read, system creates entries (workers complete checklists -> moved to history)
    match /checklistHistory/{id} {
      allow read: if isManager();
      allow create: if isAuth();
    }

    // Stock Items: all auth read (workers view stock), all auth create/update (workers add items/update stock), managers+ or inventory delete
    match /stockItems/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isManager() || isInventory();
    }

    // Stock Requests: all auth read/create (workers submit requests), managers+ or inventory update (review)
    match /stockRequests/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isManager() || isInventory();
    }

    // Recipes: all auth read, managers/inventory create/update/delete
    match /recipes/{id} {
      allow read: if isAuth();
      allow create: if isManager() || isInventory();
      allow update: if isManager() || isInventory();
      allow delete: if isManager() || isInventory();
    }

    // Stock Logs: all auth read, all auth create, managers/inventory can update (reverse actions)
    match /stockLogs/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isManager() || isInventory();
    }

    // Availability Settings: stored in organizations doc, only admins can update
    // This is part of the organizations collection, so we use the rule above
    // Rule: allow update on availabilitySettings field if isAdmin()
  }
}
